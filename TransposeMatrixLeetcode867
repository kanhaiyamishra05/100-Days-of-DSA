class Solution {
    public int[][] transpose(int[][] matrix) {
        int a=matrix.length;
        int b= matrix[0].length;
        int i,j;
        int[][] transpose = new int[b][a];
        for( i=0;i<a;i++){
            for( j = 0;j<b;j++){
                transpose[j][i]=matrix[i][j];
            }
        }
        return transpose;
    }
}
